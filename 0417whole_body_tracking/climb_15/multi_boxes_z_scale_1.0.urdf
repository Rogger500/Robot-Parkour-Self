<?xml version="1.0"?>
<robot name="multi_boxes">

  <!-- ✅ 根节点 -->
  <link name="base_link"/>

  <!-- ================= Box 1 ================= -->
  <link name="box1_link">
    <visual>
      <!-- ❗保持原始：不偏移 -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/zhukeahyew/whole_body_tracking/climb_15/box_models/box1.obj"
              scale="0.7415730337078652 0.7415730337078652 0.7415730337078652"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/zhukeahyew/whole_body_tracking/climb_15/box_models/box1.obj"
              scale="0.7415730337078652 0.7415730337078652 0.7415730337078652"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
  </link>

  <!-- ================= Box 2 ================= -->
  <link name="box2_link">
    <visual>
      <!-- ❗保持原始：不偏移 -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/zhukeahyew/whole_body_tracking/climb_15/box_models/box2.obj"
              scale="0.7415730337078652 0.7415730337078652 0.7415730337078652"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/zhukeahyew/whole_body_tracking/climb_15/box_models/box2.obj"
              scale="0.7415730337078652 0.7415730337078652 0.7415730337078652"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
  </link>

  <!-- ================= 固定连接 ================= -->

  <joint name="base_to_box1" type="fixed">
    <parent link="base_link"/>
    <child link="box1_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <joint name="base_to_box2" type="fixed">
    <parent link="base_link"/>
    <child link="box2_link"/>
    <origin xyz="0 0 0"/>
  </joint>

</robot>
